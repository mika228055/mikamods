<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN" name="MikaModsLogConfig">
    <Appenders>

        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="[%d{HH:mm:ss}] [%t/%level] [%logger]: %msg%n"/>
        </Console>

    </Appenders>

    <Loggers>
        <!-- Your loader -->
        <Logger name="loader" level="debug" additivity="false">
            <AppenderRef ref="Console"/>
        </Logger>

        <!-- Mixin logs -->
        <Logger name="org.spongepowered.asm.mixin" level="info"/>

        <!-- Root -->
        <Root level="info">
            <AppenderRef ref="Console"/>
        </Root>
    </Loggers>
</Configuration>
